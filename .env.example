# Locus-OS environment template
# Copy to `.env` (gitignored) and fill in.

# ── Neo4j (required) ──────────────────────────────────────────────────────
# Bolt URI for your Neo4j instance. Local dev default is bolt://127.0.0.1:7687.
# For non-loopback Neo4j use bolt+s:// (TLS) — plaintext bolt:// is loopback-only.
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
# REQUIRED. Locus refuses to start if this is unset, "neo4j", or "changeme".
NEO4J_PASSWORD=

# ── NVIDIA NIM (optional) ─────────────────────────────────────────────────
# When set, the agent prefers NIM over keyword classification.
# Get a free key at https://build.nvidia.com/explore/discover
# NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── HTTP server (optional overrides) ──────────────────────────────────────
# Defaults to 127.0.0.1:4000 — used by GraphQL (+ GraphiQL playground in debug).
# LOCUS_HTTP_ADDR=127.0.0.1:4000
# Locus refuses to bind a non-loopback address unless this is explicitly set to 1.
# LOCUS_ALLOW_REMOTE=0
