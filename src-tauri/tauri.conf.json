{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Locus",
  "version": "0.1.0",
  "identifier": "com.locus.os",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Locus",
        "decorations": false,
        "transparent": true,
        "fullscreen": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; connect-src 'self' https://integrate.api.nvidia.com stun:stun.l.google.com:19302; img-src 'self' data:; style-src 'self' 'unsafe-inline'; media-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "macOS": {
      "entitlements": "./entitlements.plist",
      "infoPlist": "./Info.plist"
    }
  }
}
