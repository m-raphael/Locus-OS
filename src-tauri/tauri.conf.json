{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Locus",
  "version": "0.1.0",
  "identifier": "com.locus.os",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Locus",
        "decorations": false,
        "transparent": true,
        "fullscreen": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
