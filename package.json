{
  "name": "locus",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "db:up": "brew services start neo4j",
    "db:down": "brew services stop neo4j",
    "db:logs": "tail -f /usr/local/var/log/neo4j/neo4j.log",
    "db:reset": "brew services stop neo4j && rm -rf /usr/local/var/neo4j/data && brew services start neo4j",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f neo4j",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "start": "until nc -z 127.0.0.1 7687; do sleep 2; done && cargo tauri dev",
    "start:local": "npm run db:up && until nc -z 127.0.0.1 7687; do sleep 2; done && cargo tauri dev",
    "start:docker": "npm run docker:up && until nc -z 127.0.0.1 7687; do sleep 2; done && cargo tauri dev",
    "app": "npm run db:up && cargo tauri dev",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "tokens:lint": "node scripts/export-design-tokens.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@react-three/postprocessing": "^2.19.1",
    "@tauri-apps/api": "^2",
    "gsap": "^3.15.0",
    "motion": "^12.38.0",
    "react": "^18",
    "react-dom": "^18",
    "three": "^0.184.0",
    "zustand": "^5"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-themes": "^8.6.18",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react-vite": "^8.6.18",
    "@tauri-apps/cli": "^2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "storybook": "^8.6.18",
    "typescript": "^5",
    "vite": "^8"
  }
}
